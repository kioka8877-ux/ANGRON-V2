  "blocs": [
    {
      "id": 1,
      "texte": "Why Lameen's Trivela is more spectacular than you think.",
      "start": 0.0,
      "end": 5.08
    },
    {
      "id": 2,
      "texte": "Kick with the outside of your foot.",
      "start": 5.93,
      "end": 8.65
    },
    {
      "id": 3,
      "texte": "You don't just change direction.",
      "start": 9.41,
      "end": 11.81
    },
    {
      "id": 4,
      "texte": "You flip the spin at f equals rho rv times omega.",
      "start": 12.47,
      "end": 21.65
    },
    {
      "id": 5,
      "texte": "That's the Magnus Effect.",
      "start": 22.48,
      "end": 24.24
    },
    {
      "id": 6,
      "texte": "It decides every curve in football.",
      "start": 24.92,
      "end": 27.5
    },
    {
      "id": 7,
      "texte": "Normal right foot shot.",
      "start": 27.92,
      "end": 30.54
    },
    {
      "id": 8,
      "texte": "Clockwise spin.",
      "start": 31.16,
      "end": 32.24
    },
    {
      "id": 9,
      "texte": "Ball goes right.",
      "start": 32.84,
      "end": 33.66
    },
    {
      "id": 10,
      "texte": "Goalkeeper reads it.",
      "start": 34.42,
      "end": 35.14
    },
    {
      "id": 11,
      "texte": "Easy.",
      "start": 35.42,
      "end": 35.68
    },
    {
      "id": 12,
      "texte": "Trivela.",
      "start": 37.01,
      "end": 37.47
    },
    {
      "id": 13,
      "texte": "Counterclockwise spin.",
      "start": 38.46,
      "end": 39.86
    },
    {
      "id": 14,
      "texte": "Same body position.",
      "start": 40.4,
      "end": 41.2
    },
    {
      "id": 15,
      "texte": "Ball goes left.",
      "start": 41.82,
      "end": 42.94
    },
    {
      "id": 16,
      "texte": "Lameen makes contact at 70 degrees off axis.",
      "start": 44.12,
      "end": 48.52
    },
    {
      "id": 17,
      "texte": "That's roughly 10 revolutions per second.",
      "start": 48.84,
      "end": 51.8
    },
    {
      "id": 18,
      "texte": "Double the standard shot.",
      "start": 52.12,
      "end": 54.0
    },
    {
      "id": 19,
      "texte": "The goalkeeper never had a chance.",
      "start": 54.82,
      "end": 56.94
    },
    {
      "id": 20,
      "texte": "This isn't a trick shot.",
      "start": 56.94,
      "end": 59.48
    },
    {
      "id": 21,
      "texte": "It's a physics exploit.",
      "start": 59.98,
      "end": 61.14
    },
    {
      "id": 22,
      "texte": "Bait into the geometry of contact.",
      "start": 62.26,
      "end": 64.3
    },
    {
      "id": 23,
      "texte": "The body lies.",
      "start": 65.2,
      "end": 66.26
    },
    {
      "id": 24,
      "texte": "The equations don't.",
      "start": 66.78,
      "end": 68.32
    }
  ]
}